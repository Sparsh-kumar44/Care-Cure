<!DOCTYPE html>
<html>
<head>
  <title>Bill History | Care & Cure</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .modal-overlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:999; justify-content:center; align-items:center; }
    .modal-overlay.active { display:flex; }
    .modal { background:white; padding:32px; border-radius:16px; width:360px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
    .modal h3 { font-size:18px; margin-bottom:8px; color:#1a1a1a; }
    .modal p { color:#666; font-size:14px; margin-bottom:20px; }
    .modal input { width:100%; padding:12px; border-radius:8px; border:1px solid #ddd; font-size:14px; margin-bottom:12px; text-align:center; }
    .modal-btns { display:flex; gap:10px; justify-content:center; }
    .modal-btns button { flex:1; padding:11px; border-radius:8px; border:none; cursor:pointer; font-size:14px; font-weight:500; }
    .btn-cancel-modal { background:#f0f0f0; color:#333; }
    .btn-confirm-delete { background:#e74c3c; color:white; }
    .modal-error { color:#e74c3c; font-size:13px; margin-bottom:8px; display:none; }
  </style>
</head>
<body>

<div class="container">
  <div class="sidebar">
    <h2>Care &amp; Cure</h2>
    <a href="/dashboard">Dashboard</a>
    <a href="/medicines">Medicines</a>
    <a href="/employees">Employees</a>
    <a href="/billing">Billing</a>
    <a href="/bills">Bill History</a>
    <a href="/logout">Logout</a>
  </div>

  <div class="main">
    <h1 class="page-title">Bill History</h1>

    <div class="form-box">
      <table>
        <tr>
          <th>Bill No</th>
          <th>Patient</th>
          <th>Age</th>
          <th>Gender</th>
          <th>Phone</th>
          <th>Items</th>
          <th>Total</th>
          <th>Date & Time</th>
          <th>By</th>
          <th>Actions</th>
        </tr>

        <% if (bills.length === 0) { %>
          <tr><td colspan="10">No bills generated yet</td></tr>
        <% } %>

        <% bills.forEach(b => { %>
          <tr>
            <td>#<%= b.billNo %></td>
            <td><%= b.patientName %></td>
            <td><%= b.patientAge %></td>
            <td><%= b.patientGender || '-' %></td>
            <td><%= b.patientPhone || '-' %></td>
            <td><%= b.items.length %></td>
            <td>₹<%= b.grandTotal.toFixed(2) %></td>

            <!-- ✅ FIXED DATE + TIME -->
            <td>
              <%= new Date(b.createdAt).toLocaleDateString('en-GB') %>
              <br>
              <small>
                <%= new Date(b.createdAt).toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata' }) %>
              </small>
            </td>

            <td><%= b.generatedBy %></td>

            <td>
              <a href="/print-bill/<%= b._id %>" target="_blank" class="action-edit">🖨️ Print</a>

              <% if (user && user.role === 'admin') { %>
                &nbsp;
                <a href="#" class="action-edit" style="color:#e74c3c;"
                   onclick="askDelete('<%= b._id %>', '#<%= b.billNo %> - <%= b.patientName %>'); return false;">
                  🗑️ Delete
                </a>
              <% } %>
            </td>
          </tr>
        <% }) %>

      </table>
    </div>
  </div>
</div>

<!-- Modal -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal">
    <h3>Confirm Delete</h3>
    <p id="modal-desc">Enter your admin password to delete this bill.</p>
    <p class="modal-error" id="modal-error">Incorrect password. Try again.</p>
    <input type="password" id="modal-password" placeholder="Enter your password">
    <div class="modal-btns">
      <button class="btn-cancel-modal" onclick="closeModal()">Cancel</button>
      <button class="btn-confirm-delete" onclick="confirmDelete()">Delete</button>
    </div>
  </div>
</div>

<script>
  let targetId = null;

  function askDelete(id, label) {
    targetId = id;
    document.getElementById('modal-desc').textContent = `Enter your password to delete bill: ${label}`;
    document.getElementById('modal-password').value = '';
    document.getElementById('modal-error').style.display = 'none';
    document.getElementById('deleteModal').classList.add('active');
    setTimeout(() => document.getElementById('modal-password').focus(), 100);
  }

  function closeModal() {
    document.getElementById('deleteModal').classList.remove('active');
    targetId = null;
  }

  async function confirmDelete() {
    const password = document.getElementById('modal-password').value;
    if (!password) return;

    const verifyRes = await fetch('/api/auth/verify-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password })
    });

    const verifyData = await verifyRes.json();
    if (!verifyData.valid) {
      document.getElementById('modal-error').style.display = 'block';
      document.getElementById('modal-password').value = '';
      return;
    }

    const res = await fetch('/api/bill/delete/' + targetId, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) {
      closeModal();
      location.reload();
    }
  }

  document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
</script>

</body>
</html>