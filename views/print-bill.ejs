<!DOCTYPE html>
<html>
<head>
  <title>Bill #<%= bill.billNo %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
    body { background: #f0f0f0; display: flex; justify-content: center; padding: 30px; flex-direction: column; align-items: center; }

    .bill-page {
      background: white;
      width: 210mm;
      min-height: 297mm;
      padding: 30px 40px;
      box-shadow: 0 0 20px rgba(0,0,0,0.15);
    }

    .bill-header {
      text-align: center;
      border-bottom: 3px double #111;
      padding-bottom: 16px;
      margin-bottom: 20px;
    }

    .bill-header img {
      width: 90px;
      height: 90px;
      object-fit: contain;
      display: block;
      margin: 0 auto 10px;
    }

    .bill-header h1 { font-size: 24px; font-weight: 700; letter-spacing: 0.5px; color: #111; }
    .bill-header p { font-size: 13px; color: #555; margin-top: 4px; }

    .bill-meta {
      display: flex;
      justify-content: space-between;
      margin-bottom: 20px;
      font-size: 14px;
      background: #f8f9fa;
      border-radius: 8px;
      padding: 14px 18px;
    }

    .bill-meta div { line-height: 2; }
    .bill-meta strong { color: #111; min-width: 120px; display: inline-block; }

    table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 14px; }
    thead tr { background: #1a1a1a; color: white; }
    thead th { padding: 11px 12px; text-align: left; font-weight: 500; }
    thead th:last-child { text-align: right; }
    tbody tr { border-bottom: 1px solid #eee; }
    tbody tr:nth-child(even) { background: #f9f9f9; }
    tbody td { padding: 10px 12px; }
    tbody td:last-child { text-align: right; font-weight: 600; }

    .totals { display: flex; justify-content: flex-end; margin-bottom: 30px; }
    .totals table { width: auto; min-width: 240px; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden; }
    .totals td { padding: 8px 16px; font-size: 14px; }
    .totals .grand-row { background: #1a1a1a; color: white; }
    .totals .grand-row td { font-size: 16px; font-weight: 700; padding: 12px 16px; }

    .bill-footer {
      border-top: 1px solid #ccc;
      padding-top: 20px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      font-size: 13px;
      color: #666;
    }

    .signature-box { text-align: center; }
    .signature-line { width: 160px; border-top: 1px solid #333; margin: 50px auto 6px; }

    .thank-you {
      text-align: center;
      margin-top: 28px;
      font-size: 13px;
      color: #999;
      font-style: italic;
      padding-top: 16px;
      border-top: 1px dashed #ddd;
    }

    .print-btn {
      margin-top: 20px;
      background: #4facfe;
      color: white;
      border: none;
      padding: 14px 36px;
      border-radius: 10px;
      font-size: 15px;
      cursor: pointer;
    }

    .print-btn:hover { background: #2f80ed; }

    @media print {
      body { background: white; padding: 0; }
      .bill-page { box-shadow: none; width: 100%; padding: 20px; }
      .print-btn { display: none; }
    }
  </style>
</head>
<body>

<div class="bill-page">

  <!-- Header -->
  <div class="bill-header">
    <img src="/logo.png" alt="Care & Cure Logo">
    <h1>Shri Ram Chandra Prasad Care &amp; Cure Clinic</h1>
    <p>Clinic Management System</p>
    <p>Contact: +91 94150-71809</p>
  </div>

  <!-- Patient & Bill Info -->
  <div class="bill-meta">
    <div>
      <strong>Patient Name:</strong> <%= bill.patientName %><br>
      <strong>Age:</strong> <%= bill.patientAge %> years<br>
      <% if (bill.patientGender) { %><strong>Gender:</strong> <%= bill.patientGender %><br><% } %>
      <% if (bill.patientPhone) { %><strong>Phone:</strong> <%= bill.patientPhone %><br><% } %>
    </div>
    <div style="text-align:right;">
      <strong>Bill No:</strong> #<%= bill.billNo %><br>
      <strong>Date:</strong> <%= new Date(bill.createdAt).toDateString() %><br>
      <strong>Time:</strong> <%= new Date(bill.createdAt).toLocaleTimeString() %><br>
      <strong>Generated By:</strong> <%= bill.generatedBy %>
    </div>
  </div>

  <!-- Items Table -->
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Medicine</th>
        <th>Tablets</th>
        <th>Price/Tablet</th>
        <th>Amount</th>
      </tr>
    </thead>
    <tbody>
      <% bill.items.forEach((item, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= item.name %></td>
          <td><%= item.tablets %></td>
          <td>₹<%= item.pricePerTablet %></td>
          <td>₹<%= item.total.toFixed(2) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <!-- Grand Total -->
  <div class="totals">
    <table>
      <tr class="grand-row">
        <td>Grand Total</td>
        <td>₹<%= bill.grandTotal.toFixed(2) %></td>
      </tr>
    </table>
  </div>

  <!-- Footer -->
  <div class="bill-footer">
    <div>
      <p>Generated by Care &amp; Cure System</p>
      <p>This is a computer generated bill.</p>
    </div>
    <div class="signature-box">
      <div class="signature-line"></div>
      <p>Authorised Signature</p>
    </div>
  </div>

  <p class="thank-you">Thank you for visiting Care &amp; Cure. Get well soon! 💊</p>
</div>

<button class="print-btn" onclick="window.print()">🖨️ Print Bill</button>

</body>
</html>
