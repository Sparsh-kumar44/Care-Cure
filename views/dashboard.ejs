<!DOCTYPE html>
<html>
<head>
  <title>Dashboard | Care & Cure</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">

  <div class="sidebar">
    <h2>Care &amp; Cure</h2>
    <a href="/dashboard">Dashboard</a>
    <a href="/medicines">Medicines</a>
    <a href="/employees">Employees</a>
    <a href="/billing">Billing</a>
    <a href="/bills">Bill History</a>
    <a href="/logout">Logout</a>
  </div>

  <div class="main">

    <h2 class="page-title">Welcome <%= user ? user.name + ' !' : '' %></h2>

    <div class="cards">
      <div class="card">
        <h3>Total Medicines</h3>
        <p><%= totalMeds %></p>
      </div>
      <div class="card">
        <h3>Expired Medicines</h3>
        <p><%= expiredMeds %></p>
      </div>
      <div class="card">
        <h3>Total Employees</h3>
        <p><%= totalEmployees %></p>
      </div>
    </div>

    <div class="form-box">
      <h2>Quick Actions</h2>
      <div class="btn-group">
        <a href="/medicines"><button>Add / Manage Medicines</button></a>
        <a href="/employees"><button>Manage Employees</button></a>
        <a href="/billing"><button>New Bill</button></a>
      </div>
    </div>

    <div class="form-box">
      <h2>Recent Medicines</h2>
      <table>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Total Tablets</th>
          <th>Expiry</th>
        </tr>
        <% if (medicines && medicines.length > 0) { %>
          <% medicines.forEach(m => {
            const d = new Date(m.expiry);
            const dd = String(d.getDate()).padStart(2,'0');
            const mm = String(d.getMonth()+1).padStart(2,'0');
            const yyyy = d.getFullYear();
          %>
            <tr>
              <td><%= m.medId %></td>
              <td><%= m.name %></td>
              <td><%= (m.strips || 0) * (m.tabletsPerStrip || 0) %></td>
              <td><%= dd %>/<%= mm %>/<%= yyyy %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="4">No medicines found</td></tr>
        <% } %>
      </table>
    </div>

  </div>
</div>

</body>
</html>
