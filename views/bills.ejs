<!DOCTYPE html>
<html>
<head>
  <title>Bill History | Care & Cure</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .filter-bar { display: flex; gap: 12px; align-items: center; margin-bottom: 16px; flex-wrap: wrap; }
    .filter-bar select, .filter-bar input { padding: 9px 14px; border-radius: 8px; border: 1px solid #ddd; font-size: 14px; outline: none; }
    .filter-bar select:focus, .filter-bar input:focus { border-color: #4facfe; }
    .filter-label { font-size: 13px; color: #666; font-weight: 500; }
    .badge { display: inline-block; background: #e8f4fd; color: #2f80ed; font-size: 12px; font-weight: 600; padding: 3px 10px; border-radius: 20px; margin-left: 8px; }
    .modal-overlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:999; justify-content:center; align-items:center; }
    .modal-overlay.active { display:flex; }
    .modal { background:white; padding:32px; border-radius:16px; width:360px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
    .modal h3 { font-size:18px; margin-bottom:8px; color:#1a1a1a; }
    .modal p { color:#666; font-size:14px; margin-bottom:20px; }
    .modal input { width:100%; padding:12px; border-radius:8px; border:1px solid #ddd; font-size:14px; margin-bottom:12px; text-align:center; }
    .modal-btns { display:flex; gap:10px; }
    .modal-btns button { flex:1; padding:11px; border-radius:8px; border:none; cursor:pointer; font-size:14px; font-weight:500; }
    .btn-cancel-modal { background:#f0f0f0; color:#333; }
    .btn-confirm-delete { background:#e74c3c; color:white; }
    .modal-error { color:#e74c3c; font-size:13px; margin-bottom:8px; display:none; }
    #no-results { text-align:center; color:#888; padding: 20px; display:none; }
  </style>
</head>
<body>

<div class="container">
  <div class="sidebar">
    <h2>Care &amp; Cure</h2>
    <a href="/dashboard">Dashboard</a>
    <a href="/medicines">Medicines</a>
    <a href="/employees">Employees</a>
    <a href="/billing">Billing</a>
    <a href="/bills">Bill History</a>
    <a href="/logout">Logout</a>
  </div>

  <div class="main">
    <h1 class="page-title">
      Bill History
      <span class="badge" id="count-badge">0</span>
    </h1>

    <div class="form-box">

      <!-- Filter Bar -->
      <div class="filter-bar">
        <span class="filter-label">Filter:</span>
        <select id="period-filter" onchange="applyFilters()">
          <option value="all">All Time</option>
          <option value="today">Today</option>
          <option value="week">This Week</option>
          <option value="month">This Month</option>
          <option value="last_month">Last Month</option>
          <option value="year">This Year</option>
          <option value="last_year">Last Year</option>
        </select>
       <input type="text" id="search-input" placeholder="Search patient name..." oninput="applyFilters()" autocomplete="off">
      </div>

      <table id="bills-table">
        <thead>
          <tr>
            <th>Bill No</th>
            <th>Patient</th>
            <th>Age</th>
            <th>Gender</th>
            <th>Phone</th>
            <th>Items</th>
            <th>Total</th>
            <th>Date</th>
            <th>Time</th>
            <th>By</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="bills-body">
          <% bills.forEach(b => {
            const d = new Date(b.createdAt);
            const dd = String(d.getDate()).padStart(2,'0');
            const mm = String(d.getMonth()+1).padStart(2,'0');
            const yyyy = d.getFullYear();
            const hh = String(d.getHours()).padStart(2,'0');
            const min = String(d.getMinutes()).padStart(2,'0');
            const dateStr = dd + '/' + mm + '/' + yyyy;
            const timeStr = hh + ':' + min;
          %>
          <tr
            data-date="<%= yyyy %>-<%= mm %>-<%= dd %>"
            data-name="<%= b.patientName.toLowerCase() %>">
            <td>#<%= b.billNo %></td>
            <td><%= b.patientName %></td>
            <td><%= b.patientAge %></td>
            <td><%= b.patientGender || '-' %></td>
            <td><%= b.patientPhone || '-' %></td>
            <td><%= b.items.length %></td>
            <td>Rs <%= b.grandTotal.toFixed(2) %></td>
            <td><%= dateStr %></td>
            <td><%= timeStr %></td>
            <td><%= b.generatedBy %></td>
            <td>
              <a href="/print-bill/<%= b._id %>" target="_blank" class="action-edit">Print</a>
              <% if (user && user.role === 'admin') { %>
                &nbsp;
                <a href="#" class="action-edit" style="color:#e74c3c;"
                   onclick="askDelete('<%= b._id %>', '#<%= b.billNo %> - <%= b.patientName %>'); return false;">
                  Delete
                </a>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <div id="no-results">No bills found for the selected filter.</div>
    </div>
  </div>
</div>

<!-- Delete Modal -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal">
    <h3>Confirm Delete</h3>
    <p id="modal-desc">Enter your admin password to delete this bill.</p>
    <p class="modal-error" id="modal-error">Incorrect password. Try again.</p>
    <input type="password" id="modal-password" placeholder="Enter your password">
    <div class="modal-btns">
      <button class="btn-cancel-modal" onclick="closeModal()">Cancel</button>
      <button class="btn-confirm-delete" onclick="confirmDelete()">Delete</button>
    </div>
  </div>
</div>

<script>
  let targetId = null;

  function applyFilters() {
    const period = document.getElementById('period-filter').value;
    const search = document.getElementById('search-input').value.toLowerCase().trim();
    const rows = document.querySelectorAll('#bills-body tr');
    const now = new Date();
    let visible = 0;

    rows.forEach(row => {
      const dateStr = row.dataset.date; // yyyy-mm-dd
      const name = row.dataset.name;
      const rowDate = new Date(dateStr);

      let periodMatch = true;

      if (period === 'today') {
        periodMatch = dateStr === toYMD(now);
      } else if (period === 'week') {
        const weekAgo = new Date(now); weekAgo.setDate(now.getDate() - 7);
        periodMatch = rowDate >= weekAgo;
      } else if (period === 'month') {
        periodMatch = rowDate.getMonth() === now.getMonth() && rowDate.getFullYear() === now.getFullYear();
      } else if (period === 'last_month') {
        const lm = new Date(now.getFullYear(), now.getMonth() - 1, 1);
        periodMatch = rowDate.getMonth() === lm.getMonth() && rowDate.getFullYear() === lm.getFullYear();
      } else if (period === 'year') {
        periodMatch = rowDate.getFullYear() === now.getFullYear();
      } else if (period === 'last_year') {
        periodMatch = rowDate.getFullYear() === now.getFullYear() - 1;
      }

      const nameMatch = !search || name.includes(search);
      const show = periodMatch && nameMatch;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    document.getElementById('count-badge').textContent = visible;
    document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
  }

  function toYMD(date) {
    const dd = String(date.getDate()).padStart(2, '0');
    const mm = String(date.getMonth() + 1).padStart(2, '0');
    return `${date.getFullYear()}-${mm}-${dd}`;
  }

  // Run on load to set badge count
  applyFilters();

  function askDelete(id, label) {
    targetId = id;
    document.getElementById('modal-desc').textContent = `Enter your password to delete: ${label}`;
    document.getElementById('modal-password').value = '';
    document.getElementById('modal-error').style.display = 'none';
    document.getElementById('deleteModal').classList.add('active');
    setTimeout(() => document.getElementById('modal-password').focus(), 100);
  }

  function closeModal() {
    document.getElementById('deleteModal').classList.remove('active');
    targetId = null;
  }

  async function confirmDelete() {
    const password = document.getElementById('modal-password').value;
    if (!password) return;

    const verifyRes = await fetch('/api/auth/verify-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password })
    });
    const verifyData = await verifyRes.json();

    if (!verifyData.valid) {
      document.getElementById('modal-error').style.display = 'block';
      document.getElementById('modal-password').value = '';
      return;
    }

    const res = await fetch('/api/bill/delete/' + targetId, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) { closeModal(); location.reload(); }
  }

  document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
</script>

</body>
</html>
